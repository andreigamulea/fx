<h1>Analiza US30</h1>
<p>Selectează orele pentru analiza zilnică - ora Bucuresti:</p>

<%= form_with url: home_analiza_us30_tabel_path, method: :post, local: true, data: { turbo: false } do |f| %>
  <div class="mb-3">
    <%= f.label :ora_inceput, "Ora de început:", class: "form-label" %>
    <%= f.time_select :ora_inceput, default: { hour: 0, minute: 0 }, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :ora_sfarsit, "Ora de sfârșit:", class: "form-label" %>
    <%= f.time_select :ora_sfarsit, default: { hour: 23, minute: 59 }, class: "form-control" %>
  </div>

  <div>
    <%= f.submit "Analizează", class: 'btn btn-primary' %>
  </div>
<% end %>

<%= link_to 'Pagina Principală', root_path, class: "btn btn-secondary mt-3" %>
