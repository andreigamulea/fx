<h1>Rezultatele Analizei</h1>
<%= link_to 'Pagina Principală', root_path, class: "btn btn-secondary mb-3" %>

<p><strong>Ora de început selectată:</strong> <%= @ora_inceput %></p>
<p><strong>Ora de sfârșit selectată:</strong> <%= @ora_sfarsit %></p>
<%= link_to 'Înapoi la formular', home_analiza_us30_path, class: 'btn btn-secondary mt-3' %><br>
<% if @rezultate.any? %>
  <h2>Minim și Maxim pentru fiecare zi US30</h2>
  <div class="table-responsive">
    <table class="table table-striped table-bordered table-hover">
      <thead class="table-dark">
        <tr>
          <th>#</th>
          <th>Data</th>
          <th>Ora început</th>
          <th>Ora sfârșit</th>
          <th>Minim (low)</th>
          <th>Maxim (high)</th>
        </tr>
      </thead>
      <tbody>
        <% @rezultate.each_with_index do |rezultat, index| %>
          <tr>
            <td><%= index + 1 %></td>
            <td><%= rezultat[:date] %></td>
            <td><%= rezultat[:ora_inceput] %></td>
            <td><%= rezultat[:ora_sfarsit] %></td>
            <td><%= rezultat[:min_low] %></td>
            <td><%= rezultat[:max_high] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="alert alert-warning">Nu s-au găsit înregistrări pentru intervalul selectat.</p>
<% end %>

<%= link_to 'Înapoi la formular', home_analiza_us30_path, class: 'btn btn-secondary mt-3' %>