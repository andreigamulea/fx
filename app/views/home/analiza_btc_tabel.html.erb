<h1>Rezultatele Analizei BTC</h1>
<%= link_to 'Pagina Principală', root_path %><br><br>
<p>Ora de început selectată: <%= @ora_inceput %></p>
<p>Ora de sfârșit selectată: <%= @ora_sfarsit %></p>

<% if @rezultate.any? %>
  <h2>Minim și Maxim pentru fiecare zi BTC</h2>
  <div class="table-responsive">
    <table class="table table-striped table-bordered table-hover">
      <thead class="table-dark">
        <tr>
          <th>#</th>
          <th>Data</th>
          <th>Minim (low)</th>
          <th>Maxim (high)</th>
        </tr>
      </thead>
      <tbody>
        <% @rezultate.each_with_index do |rezultat, index| %>
          <tr>
            <td><%= index + 1 %></td>
            <td><%= rezultat.date %></td>
            <td><%= rezultat.min_low %></td>
            <td><%= rezultat.max_high %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="alert alert-warning">Nu s-au găsit înregistrări pentru intervalul selectat.</p>
<% end %>

<%= link_to 'Înapoi la formular', home_analiza_btc_path, class: 'btn btn-secondary mt-3' %><br><br>
<%= link_to 'Pagina Principală', root_path %><br><br>
